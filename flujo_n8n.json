        1680,
        128
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=http://localhost:8080/carrito/{{ $json.chatId }}/item",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ productoId: $json.productoId, cantidad: $json.cantidad }) }}",
        "options": {}
      },
      "id": "a9c5f21e-5737-4133-bb36-81e1df5defc2",
      "name": "Agregar al Carrito",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1440,
        128
      ]
    },
    {
      "parameters": {
        "jsCode": "const trigger = $('Telegram Trigger').first().json;\nconst parts = trigger.callback_query.data.split('_');\n// formato: qty_{productoId}_{cantidad}\nreturn [{ json: {\n  chatId: trigger.callback_query.message.chat.id,\n  productoId: parseInt(parts[1]),\n  cantidad: parseInt(parts[2])\n} }];"
      },
      "id": "0d484010-6bd3-4d7d-8bfe-c899d8f9e085",
      "name": "Parsear Qty",
      "type": "n8n-nodes-base.code",
